{
  "metadata": {
    "id": "heat-mehler-t1-n100-N1000",
    "description": "Gaussian heat-kernel oracle at t=1 on grid [-10,10] with N=1000",
    "operator": "L = 0.5 d^2/dx^2  (ShiftChernoff1D: a=0.5, b=0, c=0)",
    "initial": "u_0(x) = exp(-x^2)",
    "oracle_formula": "u(1,x) = (1+2*1)^{-1/2} * exp(-x^2/(1+2*1)) = 3^{-1/2} * exp(-x^2/3)",
    "time": 1.0,
    "domain": [-10.0, 10.0],
    "n_grid": 1000,
    "n_chernoff_steps": 100,
    "tolerance_inf_norm": 1.0e-4,
    "note": "Sparse: every 50th grid node sampled (20 of 1000 points). Full dense comparison in tests/heat_kernel.rs."
  },
